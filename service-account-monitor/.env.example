# =============================================================================
# Service Account Monitor – Konfiguration
# Kopiere diese Datei nach .env und fülle die Werte aus.
# .env wird NICHT ins Repository committed (siehe .gitignore).
# =============================================================================

# Azure Infrastruktur
SUBSCRIPTION_ID="your-subscription-id"
RG="rg-your-resource-group"
AA="aa-your-automation-account"
LOCATION="westeurope"
MI_OBJECT_ID="your-managed-identity-object-id"

# Runbook
RUNBOOK_NAME="Invoke-ServiceAccountMonitor"
RUNTIME_ENV="psenv-sa-monitor"

# Schedule (UTC)
SCHEDULE_NAME="daily-sa-monitor"
SCHEDULE_HOUR="06"        # 06:00 UTC = 07:00 MEZ

# Entra / Mail
GROUP_NAME="Conditional Access Service Accounts"
SENDER_MAILBOX="automation@yourdomain.com"
HELPDESK_MAIL="helpdesk@yourdomain.com"
